# ============================
# Basic
# ============================
NODE_ENV=development
PORT=4000

# ============================
# Database (PostgreSQL)
# ============================
# Local:   postgresql://postgres:password@localhost:5432/project_test
# Cloud:   Use your managed DB connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/project_test"

# ============================
# JWT (SECURITY: Generate a strong random secret, 32+ chars)
# ============================
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32
JWT_EXPIRES=7d

# ============================
# CORS
# ============================
FRONTEND_URL=http://localhost:5173
ADMIN_PANEL_URL=http://localhost:5173
PATIENT_PORTAL_URL=http://localhost:5174

# ============================
# SMTP (Email)
# ============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
MAIL_FROM_NAME=UIT HealthCare
MAIL_FROM_EMAIL=your_email@gmail.com

# ============================
# MoMo Payment (TEST Mode)
# ============================
MOMO_PARTNER_CODE=YOUR_MOMO_PARTNER_CODE
MOMO_ACCESS_KEY=YOUR_MOMO_ACCESS_KEY
MOMO_SECRET_KEY=YOUR_MOMO_SECRET_KEY
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api
MOMO_RETURN_URL=http://localhost:5174/payment/return
MOMO_NOTIFY_URL=http://localhost:4000/api/payments/momo/notify

# ============================
# Google Cloud Vision (OCR) - Free tier: 1000 req/month
# ============================
GOOGLE_CLOUD_VISION_API_KEY=YOUR_API_KEY

# ============================
# OCR Microservice
# ============================
OCR_SERVICE_URL=http://localhost:8000
OCR_API_KEY=YOUR_OCR_API_KEY
